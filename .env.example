# Copy to .env and fill in your values
# cp .env.example .env

# MQTT Broker credentials (passed as CLI args to mqtt_dashboard)
MQTT_USERNAME=your_username
MQTT_PASSWORD=your_password

# MQTT TLS (optional — leave blank to use plain TCP port 1883)
# Set MQTT_CA_CERT to enable TLS on port 8883
# MQTT_CA_CERT=/path/to/broker-ca.crt
# MQTT_CLIENT_CERT=/path/to/client.crt   # only for mutual TLS
# MQTT_CLIENT_KEY=/path/to/client.key    # only for mutual TLS

# InfluxDB
INFLUX_URL=http://localhost:8086
INFLUX_TOKEN=your-influxdb-token
INFLUX_ORG=transittag
INFLUX_BUCKET=iot_data
INFLUX_ADMIN_USER=admin
INFLUX_ADMIN_PASSWORD=your-influxdb-password

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=your-grafana-password

# Google Maps Distance Matrix API
GMAPS_API_KEY=your-google-maps-api-key-here

# M-Pesa Daraja API (for STK Push payments)
# MPESA_CONSUMER_KEY=your-consumer-key
# MPESA_CONSUMER_SECRET=your-consumer-secret
# MPESA_SHORTCODE=your-shortcode
# MPESA_PASSKEY=your-lipa-na-mpesa-passkey
# MPESA_CALLBACK_URL=https://your-domain/mpesa/callback
